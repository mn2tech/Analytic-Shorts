# Same Supabase project as Timesheet (Dashboard → Settings → API).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Dev: keep port 5175 free so Vite does not jump ports (PKCE storage is per origin).
# Supabase Authentication → URL Configuration → Redirect URLs must include exactly:
#   http://localhost:5175/auth/callback
# (same port as the terminal). Use one browser profile; do not mix localhost vs 127.0.0.1.

# Optional: if true, first Google login upgrades portal_access from none → contractor
# when a profile row already exists (e.g. created by Analytics Shorts trigger). Use false in production
# if you only grant access via SQL: UPDATE shorts_user_profiles SET portal_access = 'contractor' WHERE user_id = '...';
VITE_PORTAL_AUTO_GRANT_CONTRACTOR=false

# Contractor portal AI assistant: POST /api/ai/chat is handled by the Analytics Shorts backend.
# Set ANTHROPIC_API_KEY in backend/.env on the server and restart the API (e.g. pm2).
#
# Production: set to your public API origin (no trailing slash). Dev: leave unset to use Vite /api proxy.
# VITE_API_URL=https://api.nm2tech-sas.com
#
# Dev only: optional proxy target (default http://localhost:5000).
#API_PROXY_TARGET=http://localhost:5000

# Time-off requests table (optional): database/migration_contractor_portal_dashboard.sql
# Profile: `contractors` by email — name, role, email, contractor_pay_rate (NM2TECH pay; not Prime `rate`).
# SQL: database/migration_contractors_contractor_pay_rate.sql
