# Frontend env (Vite). Copy to .env.local and fill in values.

# Optional: 8x8 JaaS for Go Live (avoids 5-min cutoff). Set in .env.local — use full AppID or tenant ID from https://8x8.vc
# VITE_JITSI_8X8_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_JITSI_8X8_TENANT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Direct YouTube upload (Create Short → Upload to YouTube)
# Get from: Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# Enable YouTube Data API v3, add your app URL to Authorized JavaScript origins.
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# CheckInn Auto-Sync Agent (Python)
# Existing manual import module path (dot notation)
# Defaults to agents.checkinnn_manual_import_adapter (backend API adapter)
# CHECKINN_IMPORT_MODULE=agents.checkinnn_manual_import_adapter
# Existing manual import callable path inside module
# CHECKINN_IMPORT_FUNCTION=import_checkinn_dta
# Existing Supabase module path (dot notation), e.g. backend.supabase_client
# CHECKINN_SUPABASE_MODULE=
# Existing Supabase client attribute path, defaults to `supabase`
# CHECKINN_SUPABASE_ATTR=supabase
# Directory to watch for CheckInn changes
# CHECKINN_WATCH_DIR=C:\CheckInn\Data
# Optional file pattern and sync metadata table
# CHECKINN_WATCH_PATTERN=*.dta
# CHECKINN_SYNC_RUNS_TABLE=innsoft_sync_runs
# Optional service name / debounce / logging
# CHECKINN_SERVICE_NAME=CheckInnSyncAgent
# CHECKINN_DEBOUNCE_SECONDS=2.5
# CHECKINN_LOG_LEVEL=INFO

# Backend auto-import API adapter options
# CHECKINN_AUTO_IMPORT_URL=http://localhost:5000/api/innsoft/auto-import
# CHECKINN_AUTO_IMPORT_TIMEOUT_SECONDS=180
